# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Supabase URL - get from your Supabase dashboard
VITE_SUPABASE_URL=your_supabase_project_url_here

# Supabase Anon Key - public key, safe for frontend
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Supabase Service Role Key (keep secret, only for server-side)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Development settings
VITE_APP_ENV=development
VITE_DEBUG=true

# Production settings (uncomment for production)
# VITE_APP_ENV=production
# VITE_DEBUG=false

# Cloudflare Turnstile site key (public; safe to expose in bundle)
# Dev test key (always passes): 1x00000000000000000000AA
# Production key: obtain from Cloudflare Dashboard → Turnstile → Add site
VITE_TURNSTILE_SITE_KEY=

# ================================================
# Email integration (Resend)
# ================================================
# RESEND_API_KEY: Resend SDK API key. Test mode keys send to special test recipients
# (delivered@resend.dev, bounced@resend.dev, complained@resend.dev). Production keys
# send to real addresses. Set in Supabase Edge Function secrets, not local .env
# (Edge Functions read from Supabase Vault).
RESEND_API_KEY=re_your_api_key_here

# RESEND_FROM_EMAIL: Sender address. Domain MUST be verified in Resend dashboard
# (DKIM, SPF DNS records published). Defaults to info@cestybezmapy.cz.
RESEND_FROM_EMAIL=info@cestybezmapy.cz

# RESEND_FROM_NAME: Display name shown to recipients ("Cesty bez mapy <info@...>").
RESEND_FROM_NAME=Cesty bez mapy

# RESEND_REPLY_TO: Override Reply-To header on transactional emails.
# Default (if unset) = cestybezmapy@gmail.com. Customer replies land in Jana's Gmail.
RESEND_REPLY_TO=cestybezmapy@gmail.com

# SITE_URL: Absolute base URL used in emails for download links. Production:
# https://www.cestybezmapy.cz (www-primary per Vercel 2026 recommendation).
# Local dev: http://localhost:5173.
SITE_URL=https://www.cestybezmapy.cz
