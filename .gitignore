# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment variables and secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
config.json
secrets.json

# Supabase specific
supabase/.env
.supabase/
supabase/.temp/
supabase/.branches/
supabase/temp/
*_backup.sql
schema_dump.sql

# Deno lockfiles (Edge Functions resolve deps from import maps in deno.json;
# lockfiles are generated locally when running `deno test`/`deno run`)
supabase/functions/**/deno.lock

# Security and certificates
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_dsa
*.ssh

# Database files
*.db
*.sqlite
*.sqlite3
db.json
database/
backups/

# SQL files - ignore ALL except migrations
*.sql
# EXCEPTION: Allow Supabase migrations (important for version control!)
!supabase/migrations/*.sql
# EXCEPTION: Allow archived pre-baseline migrations (konsolidace 2026-06-04)
!supabase/_archive/migrations-pre-baseline/*.sql
# EXCEPTION: Allow pgTAP test files
!supabase/tests/
!supabase/tests/**
!supabase/tests/database/
!supabase/tests/database/*.sql

# Large and binary files
*.zip
*.rar
*.7z
*.tar.gz
*.exe
*.dll
*.so
*.dylib
*.class
*.o
*.pyc
*.mov
*.mp4
*.avi
*.wmv
*.flv

# Specific large video file
public/video/background.mp4

# Cache and temporary files
.cache/
tmp/
temp/
*.tmp
*.temp
.sass-cache/
.parcel-cache/
coverage/

# Personal and sensitive data
personal/
private/
confidential/
test-data/
*.backup
notes.txt
todo-private.md

